# ─────────────────────────────────────────────────────────────
# fared-frontend — environment variables (NAMES ONLY, no secrets)
# Copy this file to `.env.local` and fill in real values.
#
# NOTE (handoff state): the storefront currently runs entirely on
# MOCK DATA (lib/mock-data.ts) and does NOT require any env vars to
# build or run. The variables below are the integration points for
# when the real `fared-backend` API is connected. They are dormant
# today (see lib/api.ts — implemented but not yet imported by any page).
# ─────────────────────────────────────────────────────────────

# Base URL of the fared-backend REST API (Medusa-style store API).
# Consumed by lib/api.ts (getProducts, cart, auth, orders, editorial, forum).
# Leave unset to keep running on mock data.
NEXT_PUBLIC_BACKEND_URL=

# Alternate/legacy name for the backend base URL. Referenced only in
# commented-out example fetches inside lib/mock-data.ts (not used at runtime).
# Kept for parity with CLAUDE.md, which documents the backend at this var.
NEXT_PUBLIC_MEDUSA_URL=
